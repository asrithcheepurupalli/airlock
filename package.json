{
  "name": "airlock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A privacy firewall between you and the cloud LLM. Strips and pseudonymizes sensitive data on-device before any prompt leaves the machine, then rehydrates the answer locally.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server.js",
    "build": "vite build",
    "build:ext": "vite build --config vite.ext.config.js && node scripts/build-extension.mjs",
    "preview": "vite preview",
    "package:ext": "bash scripts/package-extension.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@huggingface/transformers": "^3.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
