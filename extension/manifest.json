{
  "manifest_version": 3,
  "name": "Airlock, privacy firewall for AI",
  "version": "0.1.0",
  "description": "Strips emails, secrets, cards and your sensitive terms out of your prompt on-device before it reaches ChatGPT, Claude or Gemini, then restores them in the answer.",
  "permissions": ["storage", "offscreen"],
  "background": { "service_worker": "background.js" },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["redact.js", "license-pubkey.js", "license.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://airlock.made-by-ac.com/activate*",
        "http://localhost:5173/activate*",
        "http://localhost:4173/activate*"
      ],
      "js": ["license-pubkey.js", "license.js", "activate-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Airlock",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  }
}
