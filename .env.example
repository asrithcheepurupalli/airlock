# copy to .env (gitignored). Without a key the demo runs in client-side mock mode.
ANTHROPIC_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173,https://airlock.made-by-ac.com

# Pro licensing (api/activate.js). Generate the keypair with
#   node scripts/gen-license-keys.mjs
# then paste the contents of .license-private-key here (and into Vercel env).
LICENSE_PRIVATE_KEY=
# Identify the Gumroad product. Set ONE of these:
#   GUMROAD_PRODUCT_ID        the opaque product id (preferred; via Gumroad API)
#   GUMROAD_PRODUCT_PERMALINK the slug after /l/ in the product URL, e.g. "airlock"
GUMROAD_PRODUCT_ID=
GUMROAD_PRODUCT_PERMALINK=

# Floating-seat store (one active device per license). Optional: if unset, seat
# enforcement is OFF and a license activates on unlimited devices. Provision an
# Upstash Redis (or Vercel KV) and paste its REST creds. KV_REST_API_* also work.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
